# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'FlyerApp' do
  config = use_native_modules!

  pod 'GoogleUtilities', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      # Fix for Xcode 26: the fmt pod uses C++20 consteval which Xcode 26 rejects.
      # fmt is self-contained, so dropping it to c++17 is safe. (stripe-react-native
      # and other RN pods must stay on c++20 — they use C++20 `requires` concepts.)
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end

      target.build_configurations.each do |configuration|
        # Ensure all pods meet the minimum deployment target
        if configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 13.0
          configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
        # Allow stripe-react-native's C++/Swift interop headers
        configuration.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
  end
end
